        "# Cell 3: Build Vocabulary and Preprocess Data\n",
        "\n",
        "PAD_TOKEN = \"<PAD>\"  # index 0\n",
        "SOS_TOKEN = \"<SOS>\"  # index 1\n",
        "EOS_TOKEN = \"<EOS>\"  # index 2\n",
        "\n",
        "def build_vocab(sentences):\n",
        "    vocab = {PAD_TOKEN: 0, SOS_TOKEN: 1, EOS_TOKEN: 2}\n",
        "    for sentence in sentences:\n",
        "        for word in sentence.split():\n",
        "            if word not in vocab:\n",
        "                vocab[word] = len(vocab)\n",
        "    idx2word = {v: k for k, v in vocab.items()}\n",
        "    return vocab, idx2word\n",
        "\n",
        "def encode_sentence(sentence, vocab):\n",
        "    tokens = [SOS_TOKEN] + sentence.split() + [EOS_TOKEN]\n",
        "    return [vocab[t] for t in tokens]\n",
        "\n",
        "# Build vocabularies\n",
        "src_sentences = [p[0] for p in pairs]\n",
        "tgt_sentences = [p[1] for p in pairs]\n",
        "\n",
        "src_vocab, src_idx2word = build_vocab(src_sentences)\n",
        "tgt_vocab, tgt_idx2word = build_vocab(tgt_sentences)\n",
        "\n",
        "print(f\"Source (EN) vocab size: {len(src_vocab)}\")\n",
        "print(f\"Target (FR) vocab size: {len(tgt_vocab)}\")\n",
        "\n",
        "# Encode all sentence pairs\n",
        "encoded_pairs = [\n",
        "    (encode_sentence(en, src_vocab), encode_sentence(fr, tgt_vocab))\n",
        "    for en, fr in pairs\n",
        "]\n",
