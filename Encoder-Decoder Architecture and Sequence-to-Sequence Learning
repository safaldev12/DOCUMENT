        "# Cell 10: Translate New Sentences\n",
        "\n",
        "def translate(model, sentence, src_vocab, tgt_idx2word, max_len=12):\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        tokens = [src_vocab.get(w, 0) for w in sentence.split()]\n",
        "        src_tensor = torch.tensor([src_vocab[SOS_TOKEN]] + tokens + [src_vocab[EOS_TOKEN]],\n",
        "                                   dtype=torch.long).unsqueeze(0).to(device)\n",
        "        hidden, cell = model.encoder(src_tensor)\n",
        "        dec_input = torch.tensor([tgt_vocab[SOS_TOKEN]], dtype=torch.long).to(device)\n",
        "\n",
        "        result = []\n",
        "        for _ in range(max_len):\n",
        "            pred, hidden, cell = model.decoder(dec_input, hidden, cell)\n",
        "            top_idx = pred.argmax(dim=1).item()\n",
        "            if top_idx == tgt_vocab[EOS_TOKEN]:\n",
        "                break\n",
        "            result.append(tgt_idx2word.get(top_idx, \"?\"))\n",
        "            dec_input = torch.tensor([top_idx], dtype=torch.long).to(device)\n",
        "\n",
        "        return \" \".join(result)\n",
        "\n",
        "# Test translation\n",
        "test_sentences = [\n",
        "    \"i am happy\",\n",
