        "# Cell 5: Define the Decoder\n",
        "\n",
        "class Decoder(nn.Module):\n",
        "    \"\"\"\n",
        "    Decoder generates the output sequence one token at a time,\n",
        "    initialized with the encoder's final (hidden, cell) state.\n",
        "    \"\"\"\n",
        "    def __init__(self, output_vocab_size, embed_dim, hidden_dim):\n",
        "        super(Decoder, self).__init__()\n",
        "        self.embedding = nn.Embedding(output_vocab_size, embed_dim, padding_idx=0)\n",
        "        self.lstm = nn.LSTM(embed_dim, hidden_dim, batch_first=True)\n",
        "        self.fc_out = nn.Linear(hidden_dim, output_vocab_size)\n",
        "\n",
        "    def forward(self, tgt_token, hidden, cell):\n",
        "        # tgt_token: (batch,) → reshape to (batch, 1)\n",
        "        tgt_token = tgt_token.unsqueeze(1)\n",
        "        embedded = self.embedding(tgt_token)            # (batch, 1, embed_dim)\n",
        "        output, (hidden, cell) = self.lstm(embedded, (hidden, cell))\n",
        "        prediction = self.fc_out(output.squeeze(1))     # (batch, vocab_size)\n",
        "        return prediction, hidden, cell\n",
        "\n",
        "# Quick test\n",
        "dec = Decoder(len(tgt_vocab), EMBED_DIM, HIDDEN_DIM).to(device)\n",
        "dummy_tok = torch.tensor([1, 1], dtype=torch.long).to(device)  # SOS tokens\n",
        "pred, h2, c2 = dec(dummy_tok, h, c)\n",
        "print(f\"Decoder test passed!\")\n",
        "print(f\"  prediction shape: {pred.shape}\")  # (2, tgt_vocab_size)"
