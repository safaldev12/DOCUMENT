        "# Cell 6: Define the Full Seq2Seq Model\n",
        "\n",
        "class Seq2Seq(nn.Module):\n",
        "    \"\"\"\n",
        "    Wraps Encoder + Decoder.\n",
        "    Uses teacher forcing: randomly feeds ground-truth or predicted token.\n",
        "    \"\"\"\n",
        "    def __init__(self, encoder, decoder, tgt_vocab_size, device):\n",
        "        super(Seq2Seq, self).__init__()\n",
        "        self.encoder = encoder\n",
        "        self.decoder = decoder\n",
        "        self.tgt_vocab_size = tgt_vocab_size\n",
        "        self.device = device\n",
        "\n",
        "    def forward(self, src, tgt, teacher_forcing_ratio=0.5):\n",
        "        batch_size = src.shape[0]\n",
        "        tgt_len = tgt.shape[1]\n",
        "\n",
        "        # Store all decoder predictions\n",
        "        outputs = torch.zeros(batch_size, tgt_len, self.tgt_vocab_size).to(self.device)\n",
        "\n",
        "        # Encode source\n",
        "        hidden, cell = self.encoder(src)\n",
        "\n",
        "        # First decoder input = <SOS>\n",
        "        dec_input = tgt[:, 0]  # (batch,)\n",
        "\n",
        "        for t in range(1, tgt_len):\n",
        "            pred, hidden, cell = self.decoder(dec_input, hidden, cell)\n",
        "            outputs[:, t, :] = pred\n",
        "\n",
        "            # Teacher forcing decision\n",
        "            use_teacher = random.random() < teacher_forcing_ratio\n",
        "            top1 = pred.argmax(dim=1)\n",
        "            dec_input = tgt[:, t] if use_teacher else top1\n",
        "\n",
        "        return outputs\n",
        "\n",
        "# Build the full model\n",
        "encoder = Encoder(len(src_vocab), EMBED_DIM, HIDDEN_DIM).to(device)\n",
        "decoder = Decoder(len(tgt_vocab), EMBED_DIM, HIDDEN_DIM).to(device)\n",
        "model = Seq2Seq(encoder, decoder, len(tgt_vocab), device).to(device)\n",
        "\n",
        "total_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
        "print(f\"Seq2Seq model created successfully!\")\n",
        "print(f\"Total trainable parameters: {total_params:,}\")"
